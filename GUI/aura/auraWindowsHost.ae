    }
}

func Aura/Host/user32/set/timer(hwnd: UInt64, timer/id: UInt64, timer/ms: UInt64, callback: UInt64) : UInt64 {
    win {
        return user32/SetTimer(hwnd, timer/id, timer/ms, callback)
    }
}

func Aura/Host/user32/kill/timer(hwnd: UInt64, timer/id: UInt64) : UInt64 {
    win {
        return user32/KillTimer(hwnd, timer/id)
    }
}

func Aura/Host/gdi32/create/font(height: Int32,
                                 width: Int32,
                                 escapement: Int32,
                                 orientation: Int32,
                                 weight: Int32,
                                 italic: UInt64,
                                 underline: UInt64,
                                 strike/out: UInt64,
                                 charset: UInt64,
                                 out/precision: UInt64,
                                 clip/precision: UInt64,
                                 quality: UInt64,
                                 pitch/family: UInt64,
                                 face/name: UInt64) : UInt64 {
    win {
        return gdi32/CreateFontA(height,
                                 width,
                                 escapement,
                                 orientation,
                                 weight,
                                 italic,
                                 underline,
                                 strike/out,
                                 charset,
                                 out/precision,
                                 clip/precision,
                                 quality,
                                 pitch/family,
                                 cast<ptr<UInt8>>(face/name))
    }
}

func Aura/Host/user32/set/window/text(hwnd: UInt64, title: UInt64) : UInt64 {
    win {
        return user32/SetWindowTextA(hwnd, cast<ptr<UInt8>>(title))
    }
}

func Aura/Host/apply/glass/frame(hwnd: UInt64) : UInt64 {
    // 1. Enable Immersive Dark Mode
    var dark/mode: Int32 = 1
    Aura/Host/dwm/set/window/attribute(hwnd,
                                       Aura/Host/DWMWA/USE/IMMERSIVE/DARK/MODE,
                                       cast<UInt64>(&dark/mode),
                                       4)
    
    // 2. Enable Windows 11 Mica Backdrop (Liquid Glass)
    var mica/type: Int32 = Aura/Host/DWMSBT/MAINWINDOW
    Aura/Host/dwm/set/window/attribute(hwnd,
                                       Aura/Host/DWMWA/SYSTEMBACKDROP/TYPE,
                                       cast<UInt64>(&mica/type),
                                       4)
    
    // 3. Force Elegant Rounded Corners
    var corners: Int32 = Aura/Host/DWMWCP/ROUND
    Aura/Host/dwm/set/window/attribute(hwnd,
                                       Aura/Host/DWMWA/WINDOW/CORNER/PREFERENCE,
                                       cast<UInt64>(&corners),
                                       4)
    
    // 4. Extend Frame to allow Mica to bleed into client area
    var margins: Aura/Host/Margins
    margins\cxLeftWidth = -1
    margins\cxRightWidth = -1
    margins\cyTopHeight = -1
    margins\cyBottomHeight = -1
    Aura/Host/dwm/extend/frame(hwnd, cast<UInt64>(&margins))
    return hwnd
}

func Aura/Host/class/init(target: ptr<Aura/Host/WndClassA>, class/name: UInt64, wndproc: UInt64) : UInt64 {
    target\style = Aura/Host/CLASS/STYLE/STANDARD
    target\lpfnWndProc = wndproc
    target\cbClsExtra = 0
    target\cbWndExtra = 0
    target\hInstance = Aura/Host/current/module()
    target\hIcon = 0
    target\hCursor = Aura/Host/user32/load/cursor(0, Aura/Host/CURSOR/ARROW)
    
    // Base window background set to deeply transparent/dark brush to let Mica show through
    target\hbrBackground = Aura/Host/gdi32/create/solid/brush(Aura/Theme/Color/DeepAbyss)
    
    target\lpszMenuName = 0
    target\lpszClassName = class/name
    return Aura/Host/user32/register/class(target)
}

func Aura/Host/window/create(ex/style: UInt64,
                              class/name: UInt64,
                              window/title: UInt64,
                              style: UInt64,
                              x: Int32,
                              y: Int32,
                              width: Int32,
                              height: Int32,
                              parent: UInt64,
                              menu: UInt64,
                              param: UInt64) : UInt64 {
    return Aura/Host/user32/create/window/ex(ex/style,
                                             class/name,
                                             window/title,
                                             style,
                                             x,
                                             y,
                                             width,
                                             height,
                                             parent,
                                             menu,
                                             Aura/Host/current/module(),
                                             param)
}

func Aura/Host/window/show(hwnd: UInt64) : UInt64 {
    Aura/Host/user32/show/window(hwnd, Aura/Host/SHOW/DEFAULT)
    Aura/Host/user32/update/window(hwnd)
    return hwnd
}

func Aura/Host/window/show/if(hwnd: UInt64) : UInt64 {
    if hwnd != 0 {
        Aura/Host/window/show(hwnd)
    }
    return hwnd
}

func Aura/Host/window/set/font(hwnd: UInt64, font/handle: UInt64) : UInt64 {
    Aura/Host/user32/send/message(hwnd, Aura/Host/WM/SETFONT, font/handle, 1)
    return hwnd
}

func Aura/Host/create/label(parent: UInt64,
                            title: UInt64,
                            x: Int32,
                            y: Int32,
                            width: Int32,
                            height: Int32) : UInt64 {
    let hwnd: UInt64 = Aura/Host/window/create(0,
                                               cast<UInt64>("STATIC"),
                                               title,
                                               Aura/Host/WS/CHILD/VISIBLE,
                                               x,
                                               y,
                                               width,
                                               height,
                                               parent,
                                               0,
                                               0)
    let font: UInt64 = Aura/Host/user32/get/prop(parent, cast<UInt64>("AuraTheme_FontBody"))
    if font != 0 {
        Aura/Host/window/set/font(hwnd, font)
    }
    return hwnd
}

func Aura/Host/create/label/mono(parent: UInt64,
                                 title: UInt64,
                                 x: Int32,
                                 y: Int32,
                                 width: Int32,
                                 height: Int32) : UInt64 {
    let hwnd: UInt64 = Aura/Host/window/create(0,
                                               cast<UInt64>("STATIC"),
                                               title,
                                               Aura/Host/WS/CHILD/VISIBLE,
                                               x,
                                               y,
                                               width,
                                               height,
                                               parent,
                                               0,
                                               0)
    let font: UInt64 = Aura/Host/user32/get/prop(parent, cast<UInt64>("AuraTheme_FontMono"))
    if font != 0 {
        Aura/Host/window/set/font(hwnd, font)
    }
    return hwnd
}

func Aura/Host/create/panel(parent: UInt64,
                            title: UInt64,
                            x: Int32,
                            y: Int32,
                            width: Int32,
                            height: Int32) : UInt64 {
    let hwnd: UInt64 = Aura/Host/window/create(0,
                                               cast<UInt64>("STATIC"),
                                               title,
                                               Aura/Host/ACCENT/PANEL,
                                               x,
                                               y,
                                               width,
                                               height,
                                               parent,
                                               0,
                                               0)
    // Mark as custom panel to intercept background color in wndproc
    Aura/Host/user32/set/prop(hwnd, cast<UInt64>("AuraTheme_Panel"), 1)
    return hwnd
}

func Aura/Host/create/surface(parent: UInt64,
                              title: UInt64,
                              x: Int32,
                              y: Int32,
                              width: Int32,
                              height: Int32) : UInt64 {
    let hwnd: UInt64 = Aura/Host/window/create(0,
                                               cast<UInt64>("STATIC"),
                                               title,
                                               Aura/Host/ACCENT/PANEL,
                                               x,
                                               y,
                                               width,
                                               height,
                                               parent,
                                               0,
                                               0)
    Aura/Host/user32/set/prop(hwnd, cast<UInt64>("AuraTheme_Surface"), 1)
    return hwnd
}

func Aura/Host/create/divider(parent: UInt64,
                              x: Int32,
                              y: Int32,
                              width: Int32,
                              height: Int32) : UInt64 {
    let hwnd: UInt64 = Aura/Host/window/create(0,
                                               cast<UInt64>("STATIC"),
                                               cast<UInt64>(" "),
                                               Aura/Host/WS/CHILD/VISIBLE,
                                               x,
                                               y,
                                               width,
                                               height,
                                               parent,
                                               0,
                                               0)
    Aura/Host/user32/set/prop(hwnd, cast<UInt64>("AuraTheme_Divider"), 1)
    return hwnd
}

func Aura/Host/create/titlebar(parent: UInt64,
                               chrome: ptr<Aura/Host/Chrome>,
                               title: UInt64,
                               state: UInt64,
                               width: Int32) : UInt64 {
    chrome\title/bar = Aura/Host/create/panel(parent,
                                              cast<UInt64>(" "),
                                              0,
                                              0,
                                              width,
                                              64)
    chrome\title/text = Aura/Host/create/label(parent,
                                               title,
                                               24,
                                               22,
                                               width - 300,
                                               24)
    let font/title: UInt64 = Aura/Host/user32/get/prop(parent, cast<UInt64>("AuraTheme_FontTitle"))
    Aura/Host/window/set/font(chrome\title/text, font/title)

    chrome\state/text = Aura/Host/create/label/mono(parent,
                                                    state,
                                                    width - 400,
                                                    26,
                                                    376,
                                                    18)
    
    // Bottom border for the title bar
    chrome\divider = Aura/Host/create/divider(parent, 0, 63, width, 1)

    Aura/Host/window/show/if(chrome\title/bar)
    Aura/Host/window/show/if(chrome\title/text)
    Aura/Host/window/show/if(chrome\state/text)
    Aura/Host/window/show/if(chrome\divider)
    return chrome\title/bar
}

func Aura/Host/message/pump(msg: ptr<Aura/Host/Msg>) : UInt64 {
    while Aura/Host/user32/get/message(msg, 0, 0, 0) > 0 {
        Aura/Host/user32/translate/message(msg)
        Aura/Host/user32/dispatch/message(msg)
    }
    return cast<UInt64>(msg\message)
}

func Aura/Host/wndproc/default(hwnd: UInt64, msg: UInt32, wparam: UInt64, lparam: Int64) : Int64 {
    if msg == Aura/Host/WM/CLOSE {
        Aura/Host/user32/post/quit(0)
        return 0
    }
    if msg == Aura/Host/WM/DESTROY {
        Aura/Host/user32/post/quit(0)
        return 0
    }
    
    // Industrial Theming Engine: Intercept Static Control Rendering
    if msg == Aura/Host/WM/CTLCOLORSTATIC {
        let hdc: UInt64 = wparam
        let hwnd/child: UInt64 = cast<UInt64>(lparam)
        
        Aura/Host/gdi32/set/bk/mode(hdc, Aura/Host/TRANSPARENT/MODE)
        
        let is/divider: UInt64 = Aura/Host/user32/get/prop(hwnd/child, cast<UInt64>("AuraTheme_Divider"))
        if is/divider != 0 {
            return cast<Int64>(Aura/Host/user32/get/prop(hwnd, cast<UInt64>("AuraBrush_Divider")))
        }

        let is/surface: UInt64 = Aura/Host/user32/get/prop(hwnd/child, cast<UInt64>("AuraTheme_Surface"))
        if is/surface != 0 {
            Aura/Host/gdi32/set/text/color(hdc, Aura/Theme/Color/TextPrimary)
            return cast<Int64>(Aura/Host/user32/get/prop(hwnd, cast<UInt64>("AuraBrush_Surface")))
        }
        
        let is/panel: UInt64 = Aura/Host/user32/get/prop(hwnd/child, cast<UInt64>("AuraTheme_Panel"))
        if is/panel != 0 {
            Aura/Host/gdi32/set/text/color(hdc, Aura/Theme/Color/TextSecondary)
            return cast<Int64>(Aura/Host/user32/get/prop(hwnd, cast<UInt64>("AuraBrush_Rail")))
        }

        // Default Label coloring based on position heuristics or raw text nature
        Aura/Host/gdi32/set/text/color(hdc, Aura/Theme/Color/TextPrimary)
        
        // Return Hollow/Null Brush so the text renders perfectly on top of the liquid glass background
        return cast<Int64>(Aura/Host/gdi32/get/stock/object(5))
    }

    return Aura/Host/user32/def/window/proc(hwnd, msg, wparam, lparam)
}
