// -----------------------------------------------------------------------------
// Aura Windows Host / Desktop Window Manager Integration
// -----------------------------------------------------------------------------

struct Aura/Host/Point {
    x: Int32
    y: Int32
}

struct Aura/Host/Msg {
    hwnd: UInt64
    message: UInt32
    wParam: UInt64
    lParam: Int64
    time: UInt32
    pt: Aura/Host/Point
    private: UInt32
}

struct Aura/Host/WndClassA {
    style: UInt32
    lpfnWndProc: UInt64
    cbClsExtra: Int32
    cbWndExtra: Int32
    hInstance: UInt64
    hIcon: UInt64
    hCursor: UInt64
    hbrBackground: UInt64
    lpszMenuName: UInt64
    lpszClassName: UInt64
}

struct Aura/Host/Chrome {
    title/bar: UInt64
    title/text: UInt64
    state/text: UInt64
    glow/strip: UInt64
    signal/text: UInt64
    divider: UInt64
}

let Aura/Host/WM/CLOSE = 0x0010
let Aura/Host/WM/DESTROY = 0x0002
let Aura/Host/WM/TIMER = 0x0113
let Aura/Host/CURSOR/ARROW = 32512
let Aura/Host/CLASS/STYLE/STANDARD = 3
let Aura/Host/SHOW/DEFAULT = 5
let Aura/Host/WS/OVERLAPPED/WINDOW = 0x10CF0000
let Aura/Host/WS/CHILD/VISIBLE = 0x50000000
let Aura/Host/ACCENT/PANEL = 0x50000000

func Aura/Host/current/module() : UInt64 {
    var teb/reg: reg<"r14", UInt64>
    let teb: UInt64 = teb/reg
    let peb: UInt64 = cast<ptr<UInt64>>(teb + 0x60)[0]
    return cast<ptr<UInt64>>(peb + 0x10)[0]
}

func Aura/Host/dwm/set/window/attribute(hwnd: UInt64, attr: UInt64, value: UInt64, size: UInt64) : UInt64 {
    win {
        return dwmapi/DwmSetWindowAttribute(hwnd, attr, value, size)
    }
}

func Aura/Host/dwm/extend/frame(hwnd: UInt64, margins: UInt64) : UInt64 {
    win {
        return dwmapi/DwmExtendFrameIntoClientArea(hwnd, margins)
    }
}

func Aura/Host/user32/load/cursor(instance: UInt64, cursor/id: UInt64) : UInt64 {
    win {
        return user32/LoadCursorA(instance, cursor/id)
    }
}

func Aura/Host/gdi32/create/solid/brush(color: UInt64) : UInt64 {
    win {
        return gdi32/CreateSolidBrush(color)
    }
}

func Aura/Host/user32/register/class(target: ptr<Aura/Host/WndClassA>) : UInt64 {
    win {
        return user32/RegisterClassA(target)
    }
}

func Aura/Host/user32/create/window/ex(ex/style: UInt64,
                                        class/name: UInt64,
                                        window/title: UInt64,
                                        style: UInt64,
                                        x: Int32,
                                        y: Int32,
                                        width: Int32,
                                        height: Int32,
                                        parent: UInt64,
                                        menu: UInt64,
                                        instance: UInt64,
                                        param: UInt64) : UInt64 {
    win {
        return user32/CreateWindowExA(ex/style,
                                      cast<ptr<UInt8>>(class/name),
                                      cast<ptr<UInt8>>(window/title),
                                      style,
                                      x,
                                      y,
                                      width,
                                      height,
                                      parent,
                                      menu,
                                      instance,
                                      param)
    }
}

func Aura/Host/user32/show/window(hwnd: UInt64, cmd: UInt64) : UInt64 {
    win {
        return user32/ShowWindow(hwnd, cmd)
    }
}

func Aura/Host/user32/update/window(hwnd: UInt64) : UInt64 {
    win {
        return user32/UpdateWindow(hwnd)
    }
}

func Aura/Host/user32/send/message(hwnd: UInt64, msg: UInt64, wparam: UInt64, lparam: UInt64) : UInt64 {
    win {
        return user32/SendMessageA(hwnd, msg, wparam, lparam)
    }
}

func Aura/Host/user32/get/prop(hwnd: UInt64, name: UInt64) : UInt64 {
    win {
        return user32/GetPropA(hwnd, cast<ptr<UInt8>>(name))
    }
}

func Aura/Host/user32/set/prop(hwnd: UInt64, name: UInt64, value: UInt64) : UInt64 {
    win {
        return user32/SetPropA(hwnd, cast<ptr<UInt8>>(name), value)
    }
}

func Aura/Host/user32/get/message(msg: ptr<Aura/Host/Msg>,
                                  hwnd: UInt64,
                                  min/msg: UInt64,
                                  max/msg: UInt64) : Int64 {
    win {
        return user32/GetMessageA(msg, hwnd, min/msg, max/msg)
    }
}

func Aura/Host/user32/translate/message(msg: ptr<Aura/Host/Msg>) : UInt64 {
    win {
        return user32/TranslateMessage(msg)
    }
}

func Aura/Host/user32/dispatch/message(msg: ptr<Aura/Host/Msg>) : Int64 {
    win {
        return user32/DispatchMessageA(msg)
    }
}

func Aura/Host/user32/post/quit(code: UInt64) : UInt64 {
    win {
        return user32/PostQuitMessage(code)
    }
}

func Aura/Host/gdi32/set/bk/mode(hdc: UInt64, mode: UInt64) : UInt64 {
    win {
        return gdi32/SetBkMode(hdc, mode)
    }
}

func Aura/Host/gdi32/set/text/color(hdc: UInt64, color: UInt64) : UInt64 {
    win {
        return gdi32/SetTextColor(hdc, color)
    }
}

func Aura/Host/gdi32/get/stock/object(object/id: UInt64) : UInt64 {
    win {
        return gdi32/GetStockObject(object/id)
    }
}

func Aura/Host/user32/def/window/proc(hwnd: UInt64, msg: UInt32, wparam: UInt64, lparam: Int64) : Int64 {
    win {
        return user32/DefWindowProcA(hwnd, msg, wparam, lparam)
    }
}

func Aura/Host/user32/message/box(hwnd: UInt64, body: UInt64, title: UInt64, style: UInt64) : UInt64 {
    win {
        return user32/MessageBoxA(hwnd,
