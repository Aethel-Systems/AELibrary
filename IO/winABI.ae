// -----------------------------------------------------------------------------
// Win/ABI - Native Windows x64 ABI Invoke Bridges
// -----------------------------------------------------------------------------

hardware func Win/ABI/invoke0(target: UInt64): UInt64 {
    hardware {
        var rax: reg<"rax", UInt64>
        var rsp: reg<"rsp", UInt64>
        let old/sp: UInt64 = rsp
        let work/sp: UInt64 = (old/sp - 32) & 0xFFFFFFFFFFFFFFF0
        rsp = work/sp
        rax = target
        hardware\isa\call()
        rsp = old/sp
        return rax
    }
}

hardware func Win/ABI/invoke1(target: UInt64, a0: UInt64): UInt64 {
    hardware {
        var rax: reg<"rax", UInt64>
