        if row == 4 { return 0x07E00 }
        if row == 5 { return 0x02C00 }
        if row == 6 { return 0x02C00 }
        if row == 7 { return 0x02C00 }
        if row == 8 { return 0x1FFC0 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    if ch == 90 {
        if row == 0 { return 0x00000 }
        if row == 1 { return 0x3FFD0 }
        if row == 2 { return 0x3C7C0 }
        if row == 3 { return 0x28F40 }
        if row == 4 { return 0x02D00 }
        if row == 5 { return 0x07800 }
        if row == 6 { return 0x0F0D0 }
        if row == 7 { return 0x2D0E0 }
        if row == 8 { return 0x3FFE0 }
        if row == 9 { return 0x00000 }
        if row == 10 { return 0x00000 }
        if row == 11 { return 0x00000 }
        return 0
    }
    return 0
}

func Gfx/GlyphAL(packed: UInt32, col: UInt32) : UInt32 {
    let shift: UInt32 = (GLYPH/WIDTH - 1 - col) * 2
    return (packed >> shift) & 0x3
}

func Gfx/GlyphAC(level: UInt32) : UInt32 {
    if level == 0 {
        return 0
    }
    if level == 1 {
        return 132
    }
    if level == 2 {
        return 224
    }
    return 255
}

func Gfx/DrawGL(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, ch: UInt8, color: UInt32, scale: UInt32, alpha/factor: UInt32) {
    let row: UInt32 = 0
    while row < GLYPH/HEIGHT {
        let packed: UInt32 = Gfx/GlyphAR(ch, row)
        let col: UInt32 = 0
        while col < GLYPH/WIDTH {
            let coverage: UInt32 = Gfx/GlyphAC(Gfx/GlyphAL(packed, col))
            let alpha: UInt32 = Gfx/AlphaM(coverage, alpha/factor)
            if alpha != 0 {
                let sy: UInt32 = 0
                while sy < scale {
                    let sx: UInt32 = 0
                    while sx < scale {
                        Gfx/PixelB(back, x + (col * scale) + sx, y + (row * scale) + sy, color, alpha)
                        sx = sx + 1
                    }
                    sy = sy + 1
                }
            }
            col = col + 1
        }
        row = row + 1
    }
}

func Gfx/DrawG(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, ch: UInt8, style: ptr<AER/TEXT/STYLE>) {
    let halo: UInt32 = 0
    if style\scale > 1 {
        halo = style\scale - 1
    }

    if style\shadow/alpha != 0 {
        Gfx/DrawGL(back, x + 1, y + 1, ch, style\shadow/color, style\scale, style\shadow/alpha)
    }
    if style\glow/alpha != 0 {
        if x >= halo {
            Gfx/DrawGL(back, x - halo, y, ch, style\glow/color, style\scale, style\glow/alpha)
        }
        Gfx/DrawGL(back, x + halo, y, ch, style\glow/color, style\scale, style\glow/alpha)
        if y >= halo {
            Gfx/DrawGL(back, x, y - halo, ch, style\glow/color, style\scale, style\glow/alpha)
        }
        Gfx/DrawGL(back, x, y + halo, ch, style\glow/color, style\scale, style\glow/alpha)
    }
    if style\scale > 1 {
        Gfx/DrawGL(back, x + 1, y, ch, style\color, style\scale, 96)
        Gfx/DrawGL(back, x, y + 1, ch, style\color, style\scale, 64)
    }
    Gfx/DrawGL(back, x, y, ch, style\color, style\scale, ALPHA/MAX)
}

func Gfx/DrawL(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, a: UInt8, b: UInt8, c: UInt8, d: UInt8, e: UInt8, f: UInt8, g: UInt8, h: UInt8, i: UInt8, j: UInt8, len: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = Gfx/TextA(style)
    if len > 0 { Gfx/DrawG(back, x + (0 * advance), y, a, style) }
    if len > 1 { Gfx/DrawG(back, x + (1 * advance), y, b, style) }
    if len > 2 { Gfx/DrawG(back, x + (2 * advance), y, c, style) }
    if len > 3 { Gfx/DrawG(back, x + (3 * advance), y, d, style) }
    if len > 4 { Gfx/DrawG(back, x + (4 * advance), y, e, style) }
    if len > 5 { Gfx/DrawG(back, x + (5 * advance), y, f, style) }
    if len > 6 { Gfx/DrawG(back, x + (6 * advance), y, g, style) }
    if len > 7 { Gfx/DrawG(back, x + (7 * advance), y, h, style) }
    if len > 8 { Gfx/DrawG(back, x + (8 * advance), y, i, style) }
    if len > 9 { Gfx/DrawG(back, x + (9 * advance), y, j, style) }
}

func Gfx/DrawU(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, min/digits: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let div: UInt32 = DEC/THOUSAND * DEC/TEN
    let started: UInt32 = 0
    let pos: UInt32 = 0
    let advance: UInt32 = Gfx/TextA(style)
    while div > 0 {
        let digit: UInt32 = (value / div) % DEC/TEN
        if digit != 0 || started != 0 || div == 1 || min/digits > pos + 1 {
            Gfx/DrawG(back, x + (pos * advance), y, cast<UInt8>(48 + digit), style)
            started = 1
            pos = pos + 1
        }
        div = div / DEC/TEN
    }
}

func Gfx/DrawT(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = Gfx/TextA(style)
    Gfx/DrawG(back, x, y, cast<UInt8>(48 + ((value / DEC/TEN) % DEC/TEN)), style)
    Gfx/DrawG(back, x + advance, y, cast<UInt8>(48 + (value % DEC/TEN)), style)
}

func Gfx/DrawF(back: ptr<AER/BACK/BUFFER>, x: UInt32, y: UInt32, value: UInt32, style: ptr<AER/TEXT/STYLE>) {
    let advance: UInt32 = Gfx/TextA(style)
    Gfx/DrawG(back, x, y, cast<UInt8>(48 + ((value / DEC/THOUSAND) % DEC/TEN)), style)
    Gfx/DrawG(back, x + advance, y, cast<UInt8>(48 + ((value / DEC/HUNDRED) % DEC/TEN)), style)
    Gfx/DrawG(back, x + (2 * advance), y, cast<UInt8>(48 + ((value / DEC/TEN) % DEC/TEN)), style)
    Gfx/DrawG(back, x + (3 * advance), y, cast<UInt8>(48 + (value % DEC/TEN)), style)
}
