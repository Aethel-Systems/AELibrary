struct AER/TEXT/STYLE {
    color: UInt32
    glow/color: UInt32
    shadow/color: UInt32
    glow/alpha: UInt32
    shadow/alpha: UInt32
    scale: UInt32
    tracking: UInt32
}

func Gfx/TextA(style: ptr<AER/TEXT/STYLE>) : UInt32 {
    return (GLYPH/ADVANCE * style\scale) + style\tracking
}

